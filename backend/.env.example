# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── JWT (change in production!) ──────────────────────────────────
JWT_SECRET=dev-secret-change-in-prod

# ─── PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=reminder
DB_PASS=reminder
DB_NAME=reminder_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AI / Claude (get from console.anthropic.com) ─────────────────
# Leave blank to run in offline dev mode (no AI parsing)
ANTHROPIC_API_KEY=

# ─── Firebase Cloud Messaging ─────────────────────────────────────
# Leave blank to log notifications to console in dev mode
FCM_SERVER_KEY=

# ─── MinIO / S3 (for image uploads) ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=reminder-images
